# =============================================================================
# Backend .gitignore — Python · FastAPI · uv
# =============================================================================


# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env/

# -----------------------------------------------------------------------------
# Environment variables / secrets
# Never commit credentials or local config.
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example        # allow a committed template

# -----------------------------------------------------------------------------
# Python byte-code & caches
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]            # covers .pyc, .pyo, .pyd
*$py.class

# -----------------------------------------------------------------------------
# Distribution / packaging
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# Database files
# SQLite databases produced at runtime — never commit data files.
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Test & coverage artefacts
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
coverage/
htmlcov/
*.coveragerc~
nosetests.xml
test-results/

# -----------------------------------------------------------------------------
# Type checking
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/

# -----------------------------------------------------------------------------
# Linting / formatting caches
# -----------------------------------------------------------------------------
.ruff_cache/

# -----------------------------------------------------------------------------
# uv
# uv.lock IS intentionally committed so that the exact dependency tree can be
# reproduced by every contributor and in CI.  Do NOT add uv.lock here.
# -----------------------------------------------------------------------------
# (nothing to ignore — keep uv.lock tracked)

# -----------------------------------------------------------------------------
# Jupyter Notebooks (if used for experimentation)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Miscellaneous runtime files
# -----------------------------------------------------------------------------
*.pid
*.seed
*.swp
*.swo
